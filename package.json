{
  "name": "eslint-plugin-jsdoc-tag-lines",
  "version": "1.0.1",
  "description": "ESLint plugin for stricter JSDoc tag-line formatting.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "rules/**"
  ],
  "scripts": {
    "all-checks": "npm run lint && npm test",
    "eslint": "eslint .",
    "lint": "npm run eslint",
    "release:patch": "release-patch",
    "test": "node --test spec/*.test.js"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "jsdoc",
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaspernj/eslint-plugin-jsdoc-tag-lines.git"
  },
  "author": "kasper@diestoeckels.de",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kaspernj/eslint-plugin-jsdoc-tag-lines/issues"
  },
  "homepage": "https://github.com/kaspernj/eslint-plugin-jsdoc-tag-lines#readme",
  "peerDependencies": {
    "eslint": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "release-patch": "^1.0.0"
  }
}
